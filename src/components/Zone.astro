---
interface Props {
  titre?: string;
  image: any;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  carteUrl?: string;
}

const {
  titre = "Ma zone d'intervention",
  image,
  imageAlt = "Zone d'intervention",
  imageWidth = 823,
  imageHeight = 492,
  carteUrl = "#"
} = Astro.props;
---

<section class="zone">
  <h2>{titre}</h2>
  <a href={carteUrl} target="_blank" rel="noopener noreferrer" data-aos="fade-up">
    <img
      src={image.src}
      alt={imageAlt}
      width={imageWidth}
      height={imageHeight}
    />
  </a>
</section>


    <style>
.zone {
  text-align: center;
  background: var(--bg-marble);
  padding-bottom: 1rem;
}

.zone > h2 {
  color: var(--color-text);
}

.zone img {
  border: 1px solid #000;
  border-radius: 10px;
  width: auto;
  max-width: 1400px;
}

.zone a {
  display: inline-block;
}
@media screen and (max-width: 900px) {
  .zone img {
    max-width: 95vw;
    width: 100%;
    height: auto;
  }
}

@media (max-width: 700px) {
  .zone {
    padding-bottom: 2rem;
  }
  .zone > h2 {
    font-size: clamp(28px, 8vw, 32px);
  }
}
    </style>