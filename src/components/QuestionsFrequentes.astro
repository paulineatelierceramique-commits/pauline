---
interface Question {
  question: string;
  reponse: string;
}

interface Props {
  titre?: string;
  questions?: Question[];
}

const {
  titre = "Vos questions sur les créations céramiques de Pauline",
  questions = []
} = Astro.props;
---

<section class="faq-section">
  <h2 data-aos="fade-up">{titre}</h2>
  {questions.map((item, index) => {
    const answerId = `faq-answer-${index}`;
    const buttonId = `faq-button-${index}`;

    return (
      <div class="faq-item" data-aos="fade-up" data-aos-delay={index * 100}>
        <h3 class="faq-question">
          <button
            type="button"
            class="faq-question-btn"
            id={buttonId}
            aria-expanded="false"
            aria-controls={answerId}
          >
            <span>{item.question}</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </button>
        </h3>
        <div
          class="faq-answer"
          id={answerId}
          role="region"
          aria-labelledby={buttonId}
          hidden
        >
          <p>{item.reponse}</p>
        </div>
      </div>
    );
  })}
</section>

    <style>


.faq-section {
  background: var(--color-bg2);
  padding: 2rem 10%;
}

.faq-section h2 {
  text-align: center;
  margin: 0 0 2rem;
  color: var(--color-text);

}

.faq-item {
  max-width: 900px;
  margin: 0.75rem auto;
  background: var(--color-bg1);
  border: 1px solid rgba(31, 41, 55, 0.12);
  border-radius: 12px;
  overflow: visible;

}

.faq-question {
  margin: 0;
  color: var(--color-text);

}

.faq-question-btn {
  width: 100%;
  text-align: left;
  padding: 1rem 1.25rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  background: transparent;
  border: 0;
  color: inherit;
  font: inherit;
  cursor: pointer;
  transition: background 0.25s ease;
}

.faq-toggle {
  font-size: 1.4rem;
  line-height: 1;
  color: #000;
}

.faq-answer {
  padding: 0 1.25rem 1rem;
  color: var(--color-text);
}



.faq-answer p {
  margin: 0.75rem 0 0;
}

@media (max-width: 900px) {
  .faq-section {
    padding: 2rem 5%;
  }
}
    </style>
    <script>
  document.querySelectorAll('.faq-question').forEach((question) => {
    question.addEventListener('click', () => {
      const button = question.querySelector('.faq-question-btn');
      const answer = question.nextElementSibling;

      if (!(button instanceof HTMLButtonElement)) return;
      if (!(answer instanceof HTMLElement)) return;

      const isExpanded = button.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('.faq-question-btn').forEach((btn) => {
        btn.setAttribute('aria-expanded', 'false');
      });

      document.querySelectorAll('.faq-answer').forEach((panel) => {
        if (panel instanceof HTMLElement) {
          panel.hidden = true;
        }
      });

      if (!isExpanded) {
        button.setAttribute('aria-expanded', 'true');
        answer.hidden = false;
      }
    });
  });
</script>