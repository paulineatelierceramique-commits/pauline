---
import type { ImageMetadata } from 'astro';

interface Props {
  titre: string;
  lienLabel?: string;
  lienHref?: string;
  image: ImageMetadata;
  imageAlt: string;
  
}

const {
  titre,
  lienLabel = "Découvrez mes services",
  lienHref = `${import.meta.env.BASE_URL}services`,
  image,
  imageAlt
} = Astro.props;
---

<div class="hero">
  <div class="text-hero">
    <div class="main-text">
      <h1>{titre}</h1>
    </div>

    <div class="secondary-text">
      <slot />
    </div>

    <a href={lienHref} class="bouton-fonce">{lienLabel}</a>
  </div>

  <div class="hero-img">
    <img
      src={image.src}
      alt={imageAlt}
      width={image.width}
      height={image.height}
      loading="lazy"
    />
  </div>
</div>

<style>
@keyframes zoomIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.hero {
  background-color: var(--color-bg1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: clamp(1.5rem, 4vw, 3rem);
  margin: 0;
  padding: clamp(2rem, 5vw, 4rem) 10%;
}

.text-hero {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex: 1 1 0;
  min-width: 0;
  max-width: 100%;
  margin: 0;
  padding: 0;
  color: var(--color-text);
  animation: zoomIn 0.8s ease forwards;
}

.hero-img {
  display: flex;
  flex: 1 1 0;
  min-width: 0;
  justify-content: center;
  animation: zoomIn 0.8s ease forwards;
}

.hero-img img {
  width: 100%;
  max-width: 700px;
  height: auto;
  border-radius: 12px;
}


.secondary-text :global(p) {
  margin-bottom: 1rem;
}

.secondary-text :global(a) {
  color: inherit;
}

.secondary-text :global(.coordonnees) {
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
  margin-top: 1rem;
}

.secondary-text :global(.coordonnees a) {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: inherit;
  text-decoration: none;
}

.secondary-text :global(.coordonnees img) {
  display: block;
  width: 22px;
  height: 22px;
  flex-shrink: 0;
}

.secondary-text :global(:last-child) {
  margin-bottom: 0;
}

@media screen and (max-width: 900px) {
  .hero {
    flex-direction: column;
    align-items: center;
    padding: 2rem 1rem;
    text-align: center;
  }

  .text-hero {
    width: 100%;
    align-items: center;
    margin-bottom: 1rem;
  }

  .hero-img {
    width: 100%;
  }

  .hero-img img {
    max-width: 500px;
    margin: 0 auto;
    display: block;
  }

  .bouton-fonce {
    display: block !important;
    width: fit-content;
    margin: 0.75rem auto 0 !important;
    text-align: center;
  }
}
</style>