---
interface Creation {
  image: string;
  imageAlt: string;
  imageWidth: number;
  imageHeight: number;
  titre?: string;
}

interface Props {
  titre?: string;
  intro?: string;
  creations?: Creation[];
}

const {
  titre = "Les créations de Pauline",
  intro,
  creations = []
} = Astro.props;
---

<section class="galerie-ceramique">
  <div class="galerie-contenu">
    <div class="galerie-header" data-aos="fade-up">
      <h2>{titre}</h2>
      {intro && <p>{intro}</p>}
    </div>

    <div class="galerie-masonry">
      {creations.map((creation, index) => (
        <figure class="galerie-item" data-aos="fade-up" data-aos-delay={index * 50}>
          <button
            class="galerie-button"
            type="button"
            data-image={creation.image}
            data-alt={creation.imageAlt}
            aria-label={`Agrandir l’image : ${creation.imageAlt}`}
          >
            <img
              src={creation.image}
              alt={creation.imageAlt}
              width={creation.imageWidth}
              height={creation.imageHeight}
              loading="lazy"
            />
          </button>

          {creation.titre && <figcaption>{creation.titre}</figcaption>}
        </figure>
      ))}
    </div>
  </div>
</section>

<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Agrandissement de l'image">
  <button class="lightbox-close" id="lightbox-close" aria-label="Fermer">&#x2715;</button>
  <img id="lightbox-img" src="" alt="" />
  <span class="lightbox-hint">Clic ou Échap pour fermer</span>
</div>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const closeBtn = document.getElementById('lightbox-close');

  function openLightbox(src, alt) {
    if (!lightbox || !lightboxImg) return;
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.add('open');
  }

  function closeLightbox() {
    if (!lightbox || !lightboxImg) return;
    lightbox.classList.remove('open');
    lightboxImg.src = '';
    lightboxImg.alt = '';
  }

  document.addEventListener('click', (event) => {
    const target = event.target;
    const button = target instanceof Element ? target.closest('.galerie-button') : null;

    if (button) {
      const src = button.getAttribute('data-image');
      const alt = button.getAttribute('data-alt') || '';
      if (src) openLightbox(src, alt);
      return;
    }

    if (target === lightbox || target === closeBtn) {
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeLightbox();
  });
</script>

<style>
.galerie-ceramique {
  padding-block: 2rem;
  background-color: var(--color-bg1);
  color: var(--color-text);
  width: 100%;
}

.galerie-contenu {
  max-width: 1300px;
  margin-inline: auto;
  padding-inline: clamp(1rem, 5%, 3rem);
  box-sizing: border-box;
}

.galerie-header {
  text-align: center;
  margin-bottom: 2rem;
}

.galerie-header h2 {
  margin: 0 0 1rem 0;
  color: var(--color-text);
}

.galerie-header p {
  margin: 0 auto;
  max-width: 60ch;
  color: var(--color-text);
}

.galerie-masonry {
  column-count: 3;
  column-gap: 1.5rem;
}

.galerie-item {
  break-inside: avoid;
  margin: 0 0 1.5rem;
  display: inline-block;
  width: 100%;
}

.galerie-button {
  display: block;
  width: 100%;
  padding: 0;
  margin: 0;
  border: none;
  background: none;
  cursor: zoom-in;
}

.galerie-button img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 12px;
  transition: opacity 0.25s ease, transform 0.25s ease;
}

.galerie-button:hover img {
  opacity: 0.92;
  transform: scale(1.01);
}

.galerie-item figcaption {
  margin-top: 0.5rem;
  text-align: center;
  font-size: inherit;
  color: var(--color-text);
}

/* Lightbox */
.lightbox {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.88);
  z-index: 999;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  cursor: zoom-out;
}

.lightbox.open {
  display: flex;
  animation: lbIn 0.25s ease forwards;
}

@keyframes lbIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.lightbox img {
  max-width: 90vw;
  max-height: 90vh;
  width: auto;
  height: auto;
  object-fit: contain;
  border-radius: 0.5rem;
  animation: lbZoom 0.25s ease forwards;
}

@keyframes lbZoom {
  from { transform: scale(0.92); }
  to { transform: scale(1); }
}

.lightbox-close {
  position: fixed;
  top: 1.25rem;
  right: 1.5rem;
  background: none;
  border: none;
  color: white;
  font-size: 2rem;
  cursor: pointer;
  padding: 0.25rem 0.5rem;
  border-radius: 0.375rem;
  line-height: 1;
}

.lightbox-close:hover {
  background: rgba(255, 255, 255, 0.15);
}

.lightbox-hint {
  position: fixed;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.4);
  font-size: 0.8rem;
  pointer-events: none;
}

@media (max-width: 1000px) {
  .galerie-masonry {
    column-count: 2;
  }
}

@media (max-width: 700px) {
  .galerie-ceramique {
    padding-block: 2rem;
  }

  .galerie-masonry {
    column-count: 1;
    column-gap: 0;
  }

  .galerie-item {
    margin-bottom: 1.25rem;
  }
}
</style>