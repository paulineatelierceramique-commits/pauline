---
interface Creation {
  image: string;
  imageAlt: string;
  imageWidth: number;
  imageHeight: number;
  legende?: string;
}

interface Props {
  titre?: string;
  intro?: string;
  creations?: Creation[];
}

const {
  titre = "Les créations de Pauline",
  intro,
  creations = []
} = Astro.props;
---

<section class="galerie-ceramique">
  <div class="galerie-contenu">
    <div class="galerie-header" data-aos="fade-up">
      <h2>{titre}</h2>
      {intro && <p>{intro}</p>}
    </div>

    <div class="galerie-masonry">
      {creations.map((creation, index) => (
        <figure class="galerie-item" data-aos="fade-up" data-aos-delay={index * 50}>
          <button
            class="galerie-button"
            type="button"
            data-index={index}
            data-image={creation.image}
            data-alt={creation.imageAlt}
            aria-label={`Agrandir l’image : ${creation.imageAlt}`}
          >
            <img
              src={creation.image}
              alt={creation.imageAlt}
              width={creation.imageWidth}
              height={creation.imageHeight}
              loading="lazy"
            />
          </button>

          {creation.legende && <figcaption>{creation.legende}</figcaption>}
        </figure>
      ))}
    </div>
  </div>
</section>

<div
  class="lightbox"
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-labelledby="lightbox-title"
>
  <h3 id="lightbox-title" class="sr-only">Image agrandie</h3>

  <div class="lightbox-topbar">
    <div class="lightbox-counter" id="lightbox-counter" aria-live="polite"></div>
    <button class="lightbox-close" id="lightbox-close" aria-label="Fermer" type="button">&#x2715;</button>
  </div>

  <button class="lightbox-nav lightbox-prev" id="lightbox-prev" type="button" aria-label="Image précédente">
    &#8592;
  </button>

  <img id="lightbox-img" src="" alt="" />

  <button class="lightbox-nav lightbox-next" id="lightbox-next" type="button" aria-label="Image suivante">
    &#8594;
  </button>

  <span class="lightbox-hint">Balayage, flèches clavier ou boutons pour naviguer</span>
</div>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLElement | null;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement | null;
  const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement | null;
  const counter = document.getElementById('lightbox-counter') as HTMLElement | null;
  const galerieButtons = Array.from(document.querySelectorAll('.galerie-button')) as HTMLButtonElement[];

  let lastTrigger: HTMLElement | null = null;
  let currentIndex = 0;
  let touchStartX = 0;
  let touchStartY = 0;

  const images = galerieButtons.map((button) => ({
    src: button.getAttribute('data-image') || '',
    alt: button.getAttribute('data-alt') || ''
  }));

  function updateCounter() {
    if (!counter || !images.length) return;
    counter.textContent = `${currentIndex + 1} / ${images.length}`;
  }

  function updateLightbox(index: number) {
    if (!lightboxImg || !images[index]) return;
    currentIndex = index;
    lightboxImg.src = images[index].src;
    lightboxImg.alt = images[index].alt;
    updateCounter();
  }

  function openLightbox(index: number, trigger: HTMLElement) {
    if (!lightbox || !lightboxImg || !closeBtn || !images[index]) return;
    updateLightbox(index);
    lightbox.classList.add('open');
    lastTrigger = trigger;
    closeBtn.focus();
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox || !lightboxImg) return;
    lightbox.classList.remove('open');
    lightboxImg.src = '';
    lightboxImg.alt = '';
    if (counter) counter.textContent = '';
    document.body.style.overflow = '';
    if (lastTrigger) lastTrigger.focus();
  }

  function showNext() {
    if (!images.length) return;
    const nextIndex = (currentIndex + 1) % images.length;
    updateLightbox(nextIndex);
  }

  function showPrev() {
    if (!images.length) return;
    const prevIndex = (currentIndex - 1 + images.length) % images.length;
    updateLightbox(prevIndex);
  }

  document.addEventListener('click', (event) => {
    const target = event.target;
    const button = target instanceof Element ? target.closest('.galerie-button') : null;

    if (button instanceof HTMLElement) {
      const index = Number(button.getAttribute('data-index'));
      if (!Number.isNaN(index)) openLightbox(index, button);
      return;
    }

    if (target === closeBtn) {
      closeLightbox();
      return;
    }

    if (target === prevBtn) {
      showPrev();
      return;
    }

    if (target === nextBtn) {
      showNext();
      return;
    }

    if (target === lightbox) {
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (!lightbox?.classList.contains('open')) return;

    if (event.key === 'Escape') {
      closeLightbox();
    }

    if (event.key === 'ArrowRight') {
      showNext();
    }

    if (event.key === 'ArrowLeft') {
      showPrev();
    }
  });

  lightboxImg?.addEventListener('touchstart', (event) => {
    touchStartX = event.changedTouches[0].clientX;
    touchStartY = event.changedTouches[0].clientY;
  }, { passive: true });

  lightboxImg?.addEventListener('touchend', (event) => {
    const touchEndX = event.changedTouches[0].clientX;
    const touchEndY = event.changedTouches[0].clientY;
    const deltaX = touchEndX - touchStartX;
    const deltaY = touchEndY - touchStartY;

    if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > Math.abs(deltaY)) {
      if (deltaX < 0) {
        showNext();
      } else {
        showPrev();
      }
    }
  }, { passive: true });
</script>

<style>
.galerie-ceramique {
  padding-block: 2rem;
  background-color: var(--color-bg1);
  color: var(--color-text);
  width: 100%;
  position: relative;
}

.galerie-contenu {
  max-width: 1300px;
  margin-inline: auto;
  padding-inline: clamp(1rem, 5%, 3rem);
  box-sizing: border-box;
}

.galerie-header {
  text-align: center;
  margin-bottom: 2rem;
}

.galerie-header h2 {
  margin: 0 0 1rem 0;
  color: var(--color-text);
}

.galerie-header p {
  margin: 0 auto;
  max-width: 60ch;
  color: var(--color-text);
}

.galerie-masonry {
  column-count: 3;
  column-gap: 1.5rem;
}

.galerie-item {
  break-inside: avoid;
  margin: 0 0 1.5rem;
  display: inline-block;
  width: 100%;
}

.galerie-button {
  display: block;
  width: 100%;
  padding: 0;
  margin: 0;
  border: none;
  background: none;
  cursor: zoom-in;
}

.galerie-button img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 12px;
  transition: opacity 0.25s ease, transform 0.25s ease;
}

.galerie-button:hover img {
  opacity: 0.92;
  transform: scale(1.01);
}

.galerie-item figcaption {
  margin-top: 0.5rem;
  text-align: center;
  font-size: inherit;
  color: var(--color-text);
}

.lightbox {
  display: none;
  position: fixed;
  inset: 0;
  left: 0;
  right: 0;
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
  overflow-y: auto;
  background: rgba(0, 0, 0, 0.88);
  z-index: 999;
  padding: 1.5rem;
  box-sizing: border-box;
  cursor: zoom-out;
  text-align: center;
}

.lightbox.open {
  display: block;
  animation: lbIn 0.25s ease forwards;
}

@keyframes lbIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.lightbox-topbar {
  position: fixed;
  top: 1rem;
  left: 1rem;
  right: 1rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  pointer-events: none;
}

.lightbox-counter {
  color: rgba(255, 255, 255, 0.92);
  font-size: 0.95rem;
  letter-spacing: 0.02em;
  pointer-events: auto;
}

.lightbox img {
  display: block;
  margin: 5vh auto 0;
  max-width: 100%;
  width: auto;
  height: auto;
  max-height: 82svh;
  object-fit: contain;
  border-radius: 0.5rem;
  animation: lbZoom 0.25s ease forwards;
}

@keyframes lbZoom {
  from { transform: scale(0.92); }
  to { transform: scale(1); }
}

.lightbox-close {
  background: none;
  border: none;
  color: white;
  font-size: 2rem;
  cursor: pointer;
  padding: 0.25rem 0.5rem;
  border-radius: 0.375rem;
  line-height: 1;
  pointer-events: auto;
}

.lightbox-nav {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255, 255, 255, 0.12);
  border: none;
  color: white;
  width: 44px;
  height: 44px;
  border-radius: 999px;
  font-size: 1.4rem;
  line-height: 1;
  display: grid;
  place-items: center;
  cursor: pointer;
}

.lightbox-prev {
  left: 1rem;
}

.lightbox-next {
  right: 1rem;
}

.lightbox-close:hover,
.lightbox-nav:hover {
  background: rgba(255, 255, 255, 0.15);
}

.lightbox-hint {
  position: fixed;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.55);
  font-size: 0.8rem;
  pointer-events: none;
}

.galerie-ceramique::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 80%;
  height: 2px;
  background: linear-gradient(
    to right,
    transparent,
    var(--color-bg2),
    transparent
  );
}

@media (max-width: 1000px) {
  .galerie-masonry {
    column-count: 2;
  }
}

@media (max-width: 700px) {
  .galerie-ceramique {
    padding-block: 2rem;
  }

  .galerie-masonry {
    column-count: 1;
    column-gap: 0;
  }

  .galerie-item {
    margin-bottom: 1.25rem;
  }

  .lightbox {
    padding: 1rem;
  }

  .lightbox-topbar {
    top: 0.75rem;
    left: 0.75rem;
    right: 0.75rem;
  }

  .lightbox-counter {
    font-size: 0.85rem;
  }

  .lightbox img {
    max-width: 100%;
    max-height: 82svh;
  }

  .lightbox-close {
    font-size: 1.75rem;
  }

  .lightbox-nav {
    width: 40px;
    height: 40px;
    font-size: 1.1rem;
  }

  .lightbox-prev {
    left: 0.5rem;
  }

  .lightbox-next {
    right: 0.5rem;
  }

  .lightbox-hint {
    bottom: 1rem;
    font-size: 0.75rem;
  }
}
</style>