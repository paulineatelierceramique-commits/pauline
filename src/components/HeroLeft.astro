---
import type { ImageMetadata } from 'astro';

interface Props {
  titre: string;
  lienLabel?: string;
  lienHref?: string;
  image: ImageMetadata;
  imageAlt: string;
  imageWidth?: number;
  imageHeight?: number;
}

const {
  titre,
  lienLabel,
  lienHref = `${import.meta.env.BASE_URL}apropos`,
  image,
  imageAlt,
  imageWidth = 600,
  imageHeight = 399
} = Astro.props;
---

<div class="hero">
  <div class="hero-img" data-aos="fade-right">
    <img
      src={image.src}
      alt={imageAlt}
      width={imageWidth}
      height={imageHeight}
      loading="lazy"
    />
  </div>

  <div class="text-hero" data-aos="fade-left">
    <div class="main-text"><h2>{titre}</h2></div>

    <div class="secondary-text">
      <slot />
    </div>

    {lienLabel && (
      <a href={lienHref} class="bouton-fonce">{lienLabel}</a>
    )}
  </div>
</div>

<style>

.hero {
  background: var(--color-bg2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: clamp(1.5rem, 4vw, 3rem);
  margin: 0;
  padding: clamp(2rem, 5vw, 4rem) 10%;
}

.text-hero {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex: 1 1 0;
  min-width: 0;
  margin: 0;
  padding: 0;
  color: var(--color-text);
}

.hero-img {
  display: flex;
  flex: 1 1 0;
  min-width: 0;
  justify-content: center;
}

.hero-img img {
  width: 100%;
  max-width: 700px;
  height: auto;
  border-radius: 12px;
}

.secondary-text :global(p) {
  margin-bottom: 1rem;
}

.secondary-text :global(h3) {
  margin: 1.5rem 0 0.75rem;
}

.secondary-text :global(ul) {
  list-style: disc;
  padding-left: 1.2rem;
  margin: 1rem 0;
}

.secondary-text :global(li) {
  margin-bottom: 0.5rem;
  list-style-position: outside;
}

.secondary-text :global(li::marker) {
  color: var(--color-button);
}

.secondary-text :global(a) {
  color: inherit;
}

.secondary-text :global(:last-child) {
  margin-bottom: 0;
}

@media screen and (max-width: 900px) {
  .hero {
    flex-direction: column;
    align-items: center;
    padding: 2rem 1rem;
    text-align: center;
  }

  .text-hero {
    width: 100%;
    align-items: center;
    margin-bottom: 1rem;
    order: 1;
  }

  .hero-img {
    order: 2;
    width: 100%;
  }

  .hero-img img {
    max-width: 500px;
    margin: 0 auto;
    display: block;
  }

  .bouton-fonce {
    display: block !important;
    width: fit-content;
    margin: 0.75rem auto 0 !important;
    text-align: center;
  }
}
</style>