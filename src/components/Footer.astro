---
import logo from '../images/logopauline.svg';
import { siteConfig } from '../config/site.ts';
import footerBg from '../images/imagebg.webp';



interface LinkItem {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  liens?: LinkItem[];
  liensLegaux?: LinkItem[];
  createur?: string;
  lienCreateur?: string;
}

const {
  liens = [
    { label: "Accueil", href: `${import.meta.env.BASE_URL}` },
   // { label: "Boutique", href: "https://pauline-rebufat.bigcartel.com/",external: true },
      { label: "Boutique", href: `${import.meta.env.BASE_URL}/boutiqueprovisoire` },
    { label: "À propos", href: `${import.meta.env.BASE_URL}/apropos` },
    { label: "Contact", href: `${import.meta.env.BASE_URL}/contact` }
  ],
  liensLegaux = [
    { label: "Mentions légales", href: `${import.meta.env.BASE_URL}/mentionslegales` },
    { label: "Politique de confidentialité", href: `${import.meta.env.BASE_URL}/politiqueconfidentialite` }
  ],
  createur = "Pas à page",
  lienCreateur = "https://pasapage.fr"
} = Astro.props;

const year = new Date().getFullYear();
---

<footer style={`--footerBg: url('${footerBg.src}')`}>



  <div class="footer-logo">
    <img src={logo.src} alt={`Logo ${siteConfig.name}`} width="50" height="50" />
  </div>

  <div class="footer-menu">
    <p>Parcourir</p>
    {liens.map((lien) => (
      <div><a href={lien.href}
       target={lien.external ? "_blank" : undefined}
        rel={lien.external ? "noopener noreferrer" : undefined}
      >{lien.label}</a></div>
    ))}
  </div>

  <div class="footer-menu">
    <p>Aides et Légal</p>
    {liensLegaux.map((lien) => (
      <div><a href={lien.href}>{lien.label}</a></div>
    ))}

        

    <div>
  <span>&copy; {year} </span>
  {lienCreateur 
    ? <a href={lienCreateur} target="_blank" rel="noopener noreferrer">{createur}</a>
    : <span>{createur}</span>
  }
</div>
  </div>
</footer>

<style>

footer {
  background-image: var(--footerBg);
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  color: var(--color-text);
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  gap: 2rem;
  flex-wrap: wrap;
  padding: 2rem 10%;
  text-align: center;
}

.footer-menu {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.footer-menu p {
  margin: 0 0 0.5rem;
  font-size: var(--text-sm);
  font-weight: 600;
}

.footer-menu a,
.footer-menu span,
.footer-menu div {
  font-size: var(--text-sm);
}

.footer-logo img {
  height: 80px;
  width: auto;
}

@media (max-width: 900px) {
  footer {
    flex-direction: column;
    align-items: center;
    padding: 2rem 5%;
    gap: 1.5rem;
  }

  .footer-menu {
    width: 100%;
  }
}

</style>

