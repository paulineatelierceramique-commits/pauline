---
interface Lien {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  liens?: Lien[];
}

const {
  liens = [
    { label: "Accueil", href: `${import.meta.env.BASE_URL}` },
    { label: "Boutique", href: `${import.meta.env.BASE_URL}/boutiqueprovisoire` },
    { label: "À propos", href: `${import.meta.env.BASE_URL}/apropos` },
    { label: "Contact", href: `${import.meta.env.BASE_URL}/contact` }
  ]
} = Astro.props;
---

<nav class="nav" aria-label="Navigation principale">
  <ul class="desktop-links">
    {liens.map((lien) => (
      <li>
        <a
          href={lien.href}
          target={lien.external ? "_blank" : undefined}
          rel={lien.external ? "noopener noreferrer" : undefined}
        >
          {lien.label}
        </a>
      </li>
    ))}
  </ul>

  <details class="mobile-menu">
    <summary aria-label="Ouvrir le menu principal">
      <span></span>
      <span></span>
      <span></span>
    </summary>

    <ul class="mobile-panel">
      {liens.map((lien) => (
        <li>
          <a
            href={lien.href}
            target={lien.external ? "_blank" : undefined}
            rel={lien.external ? "noopener noreferrer" : undefined}
          >
            {lien.label}
          </a>
        </li>
      ))}
    </ul>
  </details>
</nav>

<style>

.nav {
  margin-left: auto;
  position: relative;
}

.desktop-links,
.mobile-panel {
  list-style: none;
  margin: 0;
  padding: 0;
}

.desktop-links li,
.mobile-panel li {
  list-style: none;
}

.desktop-links {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  font-size: var(--text-sm);
}

.desktop-links a,
.mobile-panel a {
  display: inline-flex;
  align-items: center;
  min-height: 44px;
  font-size: inherit;
  white-space: nowrap;
  text-decoration: none;
  color: inherit;
}

.desktop-links a:hover,
.desktop-links a:focus-visible,
.mobile-panel a:hover,
.mobile-panel a:focus-visible {
  color: var(--color-text-titre);
}

.mobile-menu {
  display: none;
  position: relative;
  margin-left: auto;
}

.mobile-menu summary {
  list-style: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  padding: 0;
  border-radius: 0.5rem;
  position: relative;
}

.mobile-menu summary::-webkit-details-marker {
  display: none;
}

.mobile-menu summary span {
  position: absolute;
  width: 26px;
  height: 2px;
  background: currentColor;
  display: block;
  border-radius: 999px;
  transition: transform 0.25s ease, opacity 0.2s ease;
  transform-origin: center;
}

.mobile-menu summary span:nth-child(1) {
  top: 14px;
}

.mobile-menu summary span:nth-child(2) {
  top: 21px;
}

.mobile-menu summary span:nth-child(3) {
  top: 28px;
}

.mobile-menu[open] summary span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}

.mobile-menu[open] summary span:nth-child(2) {
  opacity: 0;
}

.mobile-menu[open] summary span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

.mobile-panel {
  position: absolute;
  top: calc(100% + 0.75rem);
  right: 0;
  min-width: 220px;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  padding: 0.85rem 0.9rem;
  background: var(--color-bg1);
  color: var(--color-text);
  border: 1px solid rgba(140, 106, 42, 0.18);
  border-radius: 0.9rem;
  box-shadow: 0 10px 20px rgba(60, 40, 10, 0.08);
  z-index: 20;
}

.mobile-panel a {
  display: flex;
  align-items: center;
  padding: 0.35rem 0;
  font-size: var(--text-sm);
  line-height: 1.3;
}

@media screen and (max-width: 900px) {
  .desktop-links {
    display: none;
  }

  .mobile-menu {
    display: block;
  }
}
</style>