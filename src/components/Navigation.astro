---
interface Lien {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  liens?: Lien[];
}

const {
  liens = [
    { label: "Accueil", href: "/" },
    // { label: "Boutique", href: "https://pauline-rebufat.bigcartel.com/", external: true },
    { label: "Boutique", href: "/boutiqueprovisoire" },
    { label: "À propos", href: "/apropos" },
    { label: "Contact", href: "/contact" }
  ]
} = Astro.props;
---

<nav class="nav" aria-label="Navigation principale">
  <div class="elements desktop-links">
    <div class="links">
      {liens.map((lien) => (
        <a
          href={lien.href}
          target={lien.external ? "_blank" : undefined}
          rel={lien.external ? "noopener noreferrer" : undefined}
        >
          {lien.label}
        </a>
      ))}
    </div>
  </div>

  <details class="mobile-menu">
    <summary aria-label="Ouvrir le menu">
      <span></span>
      <span></span>
      <span></span>
    </summary>

    <div class="mobile-panel">
      {liens.map((lien) => (
        <a
          href={lien.href}
          target={lien.external ? "_blank" : undefined}
          rel={lien.external ? "noopener noreferrer" : undefined}
        >
          {lien.label}
        </a>
      ))}
    </div>
  </details>
</nav>

<style>
.nav {
  margin-left: auto;
  position: relative;
}

.elements {
  display: flex;
  justify-content: flex-end;
  margin: 0;
  padding: 0;
  font-size: 0.90em;
}

.links {
  display: flex;
  gap: 20px;
}

.links a,
.mobile-panel a {
  font-size: inherit;
  white-space: nowrap;
  text-decoration: none;
  color: inherit;
}

.mobile-menu {
  display: none;
}

.mobile-menu summary {
  list-style: none;
  cursor: pointer;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  width: 44px;
  height: 44px;
  padding: 0;
  border-radius: 0.5rem;
  position: relative;
}

.mobile-menu summary::-webkit-details-marker {
  display: none;
}

.mobile-menu summary span {
  position: absolute;
  right: 9px;
  width: 26px;
  height: 2px;
  background: currentColor;
  display: block;
  border-radius: 999px;
  transition: transform 0.25s ease, opacity 0.2s ease;
  transform-origin: center;
}

.mobile-menu summary span:nth-child(1) {
  top: 14px;
}

.mobile-menu summary span:nth-child(2) {
  top: 21px;
}

.mobile-menu summary span:nth-child(3) {
  top: 28px;
}

.mobile-menu[open] summary span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}

.mobile-menu[open] summary span:nth-child(2) {
  opacity: 0;
}

.mobile-menu[open] summary span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

.mobile-panel {
  margin-top: 0.75rem;
  min-width: 220px;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  padding: 0.85rem 0.9rem;
  background: inherit;
  color: inherit;
  border: 1px solid rgba(140, 106, 42, 0.18);
  border-radius: 0.9rem;
  box-shadow: 0 10px 20px rgba(60, 40, 10, 0.08);
}

.mobile-panel a {
  display: block;
  font-size: 0.95rem;
  line-height: 1.25;
  padding: 0.3rem 0;
}

@media screen and (max-width: 900px) {
  .desktop-links {
    display: none;
  }

  .mobile-menu {
    display: block;
    margin-left: auto;
  }
}
</style>