---
interface Membre {
  nom: string;
  role?: string;
  image?: string;
  imageAlt?: string;
  icone?: string;
}

interface Props {
  titre?: string;
  membres?: Membre[];
}

const {
  titre = "Notre équipe",
  membres = []
} = Astro.props;
---

<section class="equipe-section">
  <div class="equipe-inner">
    <h2 set:html={titre} data-aos="fade-up"/>
    <div class="equipe">
      {membres.map((membre, index) => (
        <div class="membre" data-aos="fade-up" data-aos-delay={Math.min(index * 100, 400)}>
          {membre.image && (
  <img
    src={membre.image}
    alt={membre.imageAlt ?? membre.nom}
    class="membre-img"
    width="80"
    height="80"
    loading="lazy"
  />
)}
{membre.icone && (
  <span class="membre-icone" set:html={membre.icone} />
)}
          <div class="membre-info">
            <h3>{membre.nom}</h3>
            {membre.role && <span class="membre-role">{membre.role}</span>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .equipe-section {
    background: var(--color-bg2);
    color: var(--color-text);
    width: 100%;
  }

  .equipe-inner {
    max-width: 1300px;
    width: 100%;
    margin-inline: auto;
    padding-inline: clamp(1rem, 5%, 3rem);
    padding-block: 2rem;
    box-sizing: border-box;
  }

  .equipe {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .membre {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-block: 1rem;
  }

  .membre + .membre {
    border-left: 1px solid oklch(0 0 0 / 0.15);
    padding-left: 1rem;
  }

  .membre-img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;  /* ratio préservé mais remplit la boite   */
    max-width: 100%;
  }

  .membre-info {
    display: flex;
    flex-direction: column;
    text-align: center;
    gap: 0.25rem;
  }

  .membre-role {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  h2 em {
  font-weight: 400;    /* pas gras */
  font-style: italic;
  font-size: 0.85em;   /* légèrement plus petit */
  opacity: 0.8;
}

.membre-icone svg {
  width: 64px;
  height: 64px;
  color: var(--color-text); /* hérite de currentColor */
}
  @media (max-width: 768px) {
    .equipe {
      grid-template-columns: 1fr 1fr;
    }

    .membre + .membre {
      border-left: none;
    }

    .membre:nth-child(n+3) {
      border-top: 1px solid oklch(0 0 0 / 0.15);
      padding-top: 1rem;
    }
  }

  @media (max-width: 480px) {
    .equipe {
      grid-template-columns: 1fr;
    }

    .membre + .membre {
      border-left: none;
      border-top: 1px solid oklch(0 0 0 / 0.15);
      padding-top: 1rem;
    }
  }
</style>