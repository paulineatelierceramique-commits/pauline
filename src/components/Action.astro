---
interface Props {
  titre?: string;
  texte?: string;
  lienLabel?: string;
  lienHref?: string;
}

const {
  titre = "Vous avez des questions ou l'envie d'en savoir davantage ?",
  texte = "",
  lienLabel = "Je prends contact",
  lienHref = `${import.meta.env.BASE_URL}contact`
} = Astro.props;
---

<div class="action" data-aos="fade-up">
  <div class="action-sub">
    <h2 class="action-title">{titre}</h2>
    {texte && <p class="action-text">{texte}</p>}
  </div>
  <div class="cta">
    <a href={lienHref} class="bouton-fonce">{lienLabel}</a>
  </div>
</div>

    <style>

.action {
  background-color: var(--color-bg1);
  color: var(--color-text);
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 3rem;
  flex-wrap: wrap;
  margin: 0;
  padding: 2rem 10%;
  border-bottom: 1px solid oklch(1 0 0 / 0.15);
  text-align: center;
}

.action-sub {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  max-width: 700px;
}

.action-title {
  margin: 0;
}

.action-text {
  margin: 0;
}

.cta {
  display: flex;
  justify-content: center;
  align-items: center;
}

@media (max-width: 900px) {
  .action {
    padding: 2rem 5%;
    gap: 1.5rem;
  }
}

    </style>