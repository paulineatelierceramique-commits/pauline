---
import { siteConfig } from '../config/site.ts';

const {
  title = `${siteConfig.name} - ${siteConfig.tagline}`,
  description = "Description à remplir...",
  ogTitle = title,
  ogDescription = description,
  ogImage = siteConfig.defaultOgImage,
  canonical = siteConfig.url,
  schema = null
} = Astro.props;

const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : `${siteConfig.url}${ogImage}`;

const businessData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": siteConfig.name,
  "image": siteConfig.defaultOgImage,
  "@id": `${siteConfig.url}/#business`,
  "url": siteConfig.url,
  "telephone": siteConfig.telephone,
  "email": siteConfig.email,
  "sameAs": [siteConfig.facebook],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": siteConfig.adresse.rue,
    "addressLocality": siteConfig.adresse.ville,
    "postalCode": siteConfig.adresse.codePostal,
    "addressCountry": siteConfig.adresse.pays
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": siteConfig.geo.latitude,
    "longitude": siteConfig.geo.longitude
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": siteConfig.horaires.jours,
    "opens": siteConfig.horaires.ouverture,
    "closes": siteConfig.horaires.fermeture
  }
};
---

<!-- Base -->
<meta charset="UTF-8" />
<meta name="generator" content={Astro.generator} />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
 <link rel="sitemap" href={`${import.meta.env.BASE_URL}sitemap-index.xml`} />
 <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

<!-- Open Graph -->
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content="website" />
<meta property="og:locale" content="fr_FR" />
<meta property="og:site_name" content={siteConfig.name} />

<!-- Favicons -->
<link rel="icon" type="image/png" sizes="192x192" href={`${import.meta.env.BASE_URL}favicon-192x192.png`} />
<link rel="icon" type="image/png" sizes="96x96" href={`${import.meta.env.BASE_URL}favicon-96x96.png`} />
<link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
<link rel="manifest" href={`${import.meta.env.BASE_URL}site.webmanifest`} />
<meta name="theme-color" content={siteConfig.themeColor} />

<!-- JSON-LD LocalBusiness -->
<script type="application/ld+json" set:html={JSON.stringify(businessData)} />

<!-- JSON-LD spécifique à la page (optionnel) -->
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
