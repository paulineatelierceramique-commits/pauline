---
import Navigation from './Navigation.astro';
import logo from '../images/logopauline.svg';

const {
  altLogo = "Logo",
} = Astro.props;
---
<header class="site-header">
  <a class="header-logo" href={`${import.meta.env.BASE_URL}`} aria-label="Accueil">
    <img src={logo.src} alt={altLogo} width="80" height="80" />
  </a>

  <Navigation />
</header>

<style>

.site-header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-6);
  padding: 1rem 10%;
  background: var(--color-bg1);
  color: var(--color-text);
}

.site-header::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: min(1200px, calc(100% - 2rem));
  height: 2px;
  background: linear-gradient(to right, transparent, var(--color-bg2), transparent);
}

.header-logo {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}

.header-logo img {
  width: auto;
  height: 80px;
}

@media (max-width: 900px) {
  .site-header {
    justify-content: center;
    flex-wrap: wrap;
    padding: 1rem;
  }

  .header-logo img {
    height: 64px;
  }
}
</style>