---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
title="Bientôt en ligne"
  description="Page provisoire qui annonce l'arrivée prochaine d'une boutique en ligne" >

  <section class="mentions">
    <div class="container">
      <h1>Boutique en ligne</h1>
      
      <div class="bloc" data-aos="fade-up">
        <h2>Ici prochainement : boutique en ligne</h2>
        <p>Revenez bientôt !<br>
            Ici à la rentrée <br>
            Venez découvrir mes fleurs en porcelaine<br>
            Vente en ligne

        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .mentions {
    background-color: var(--color-blanc-lin);
    color: var(--color-gris-fonce);
    width: 100%;
    padding-block: clamp(2rem, 6vw, 4rem);
  }

  .container {
    max-width: 800px;
    margin-inline: auto;
    padding-inline: clamp(1rem, 5%, 3rem);
  }

  h1 {
    margin-bottom: 2.5rem;
  }

  .bloc {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid oklch(0 0 0 / 0.10);
  }

  .bloc:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .bloc h2 {
    margin-bottom: 0.75rem;
  }

  .bloc p {
    line-height: 1.7;
  }

  a {
    color: var(--color-gris-fonce);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  a:hover {
    opacity: 0.7;
  }
</style>
    </div>
  </section>
</BaseLayout>
