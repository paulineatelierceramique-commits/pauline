---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilAriane from '../components/FilAriane.astro';
import Hero from '../components/Hero.astro';
import Formulaire from '../components/Formulaire.astro';
import Zone from '../components/Zone.astro';
import { siteConfig } from '../config/site.ts';
import monImage from '../images/apropos.webp';
import carteZone from '../images/zone.webp';
import backgroundImage from '../images/imagebg.webp';

const base = import.meta.env.BASE_URL;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "url": `${siteConfig.url}/contact`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteConfig.url },
      { "@type": "ListItem", "position": 2, "name": "Contact", "item": `${siteConfig.url}contact` }
    ]
  }
]
---

<BaseLayout
  title="Contacter Pauline Rébufat"
  description="Contactez Pauline Rébufat, céramiste dans le pays de Retz. Par téléphone, email ou formulaire. Réponse rapide à chaque message."
  canonical={`${siteConfig.url}contact`}
  ogTitle={`Contacter ${siteConfig.name}`}
  ogDescription={`Contactez ${siteConfig.name} pour toute question sur Pauline Rébufat Créations Céramiques.`}
  schema={schema}
>
  <FilAriane items={[
    { label: "Accueil", href: `${import.meta.env.BASE_URL}` },
    { label: "Contact" }
  ]} />
  
  <Hero 
     titre="Infos pratiques et contact"
    image={monImage}
    imageAlt="image de Pauline Rébufat, céramiste dans le Pays de Retz"
    lienLabel="Découvrez les céramiques de Pauline"
    lienHref={`${import.meta.env.BASE_URL}`}
  >
    <h2>Une question, ou l'envie d'en savoir plus ?</h2>
    <p>Vous cherchez une céramiste dans le Pays de Retz, une vaisselle artisanale en grès, une création décorative unique ou un stage de poterie ? Je serai heureuse d’échanger avec vous.</p>
   <div class="coordonnees">
  <div>📞 06 60 82 87 75</div>
  <div>📧 <a href="mailto:pauline.rebufat@gmail.com">pauline.rebufat@gmail.com</a></div>
  <a href="https://www.instagram.com/lesceramiquesdepauline/" target="_blank" rel="noopener noreferrer">
    <img src={`${import.meta.env.BASE_URL}icons/instagram.svg`} alt="Instagram" width="22" height="22" />
    Les céramiques de Pauline
  </a>
  <a href="https://www.facebook.com/CERAMIQUEPAULINEREBUFAT" target="_blank" rel="noopener noreferrer">
    <img src={`${import.meta.env.BASE_URL}icons/facebook.svg`} alt="Facebook" width="22" height="22" />
    Les Céramiques de Pauline
  </a>
</div>


  </Hero>

  <Formulaire
    action="/traitement-pauline"
    placeholderMessage="Bonjour ! Décrivez ici votre demande..."
    backgroundImage={backgroundImage.src}
  />

  <Zone 
      titre="Ma zone d'intervention"
      image={carteZone}
      imageAlt="carte de la zone d'intervention de Pauline Rébufat Créations céramiques"
      carteUrl="https://share.google/vCSvH5Q5oZ9kX3qUF"
  />

</BaseLayout>