---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import '../styles/global.css';
import 'aos/dist/aos.css';

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage,
  canonical,
  schema
} = Astro.props;
---

<html lang="fr">
  <head>
    <Head
      title={title}
      description={description}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      ogImage={ogImage}
      canonical={canonical}
      schema={schema}
    />
  </head>

  <body>
  <a class="skip-link" href="#main-content">Aller au contenu</a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <BackToTop />

    <div class="cursor-dot" aria-hidden="true"></div>

   <script>
  const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (finePointer.matches && !reducedMotion.matches) {
    document.documentElement.classList.add('has-custom-cursor');

    const dot = document.querySelector('.cursor-dot');
    const interactiveSelector = 'a, button, input, textarea, select, [data-cursor="hover"]';

    const showDot = () => {
      if (dot instanceof HTMLElement) dot.classList.add('is-visible');
    };

    const hideDot = () => {
      if (dot instanceof HTMLElement) dot.classList.remove('is-visible', 'is-hover', 'is-pressed');
    };

    window.addEventListener('mousemove', (event) => {
      if (!(dot instanceof HTMLElement)) return;

      dot.style.left = `${event.clientX}px`;
      dot.style.top = `${event.clientY}px`;
      showDot();
    });

    window.addEventListener('mouseout', (event) => {
      if (event.relatedTarget === null) hideDot();
    });

    window.addEventListener('mouseover', (event) => {
      if (event.relatedTarget === null) showDot();
    });

    document.addEventListener('mouseover', (event) => {
      const target = event.target;
      if (dot instanceof HTMLElement && target instanceof Element && target.closest(interactiveSelector)) {
        dot.classList.add('is-hover');
      }
    });

    document.addEventListener('mouseout', (event) => {
      const target = event.target;
      if (dot instanceof HTMLElement && target instanceof Element && target.closest(interactiveSelector)) {
        dot.classList.remove('is-hover');
      }
    });

    document.addEventListener('mousedown', () => {
      if (dot instanceof HTMLElement) dot.classList.add('is-pressed');
    });

    document.addEventListener('mouseup', () => {
      if (dot instanceof HTMLElement) dot.classList.remove('is-pressed');
    });
  }
</script>

   

    <script src="../scripts/aos.js"></script>

   
  </body>
</html>

<style>
.skip-link {
  position: absolute;
  top: -40px;
  left: 1rem;
  background: var(--color-bg1);
  color: var(--color-text);
  padding: 0.75rem 1rem;
  z-index: 10000;
}

.skip-link:focus {
  top: 1rem;
}

</style>